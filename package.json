{
  "name": "myzl",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:gh": "VITE_BASE_URL=/myzl/ run-p type-check \"build-only {@}\" --",
    "build:root": "VITE_BASE_URL=/ run-p type-check \"build-only {@}\" --",
    "preview": "npm run build-only && wrangler dev",
    "preview:vite": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "test:mutation": "stryker run",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "deploy": "npm run build-only && wrangler deploy"
  },
  "dependencies": {
    "cnchar": "^3.2.6",
    "cnchar-poly": "^3.2.6",
    "cnchar-words": "^3.2.6",
    "hanzi-writer": "^3.7.3",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "pinyin-pro": "^3.28.1",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.1",
    "@playwright/test": "^1.58.2",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.13",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.57.0",
    "prettier": "3.8.1",
    "typescript": "~6.0.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.84.1"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
